<h1>Dashboard</h1>

<% if current_user&.staff? %>
  <%= link_to 'New Candidate', new_candidate_path %>

  <%= form_tag(search_candidates_path, method: :get) do -%>
      <%= label_tag(:q, 'Search by name:') %>
      <%= text_field_tag(:q) %>
      <%= submit_tag('Search') %>
  <% end -%>

  <p>
    <% unless @dashboard_data[:headcount_targets].nil? %>
        <% @dashboard_data[:headcount_targets].each_pair do |k, v| %>
            <%= v[:name] %> target is <%= v[:target] %>, so we are looking for <%= v[:needed] %><br/>
        <% end %>
    <% end %>

    <%= candidates_table @dashboard_data[:candidates_by_status], {:include_source => true, :include_position => true, :include_events => true, :include_references => true, :include_status => true} %>

  <hr>

  <table>
    <tr>
      <th>Experience Legend</th>
    </tr>
    <% ExperienceLevel.all.each do |experience_level| %>
        <tr>
          <td><%= color_span(experience_level, {text: get_name(experience_level), bold: true}) %></td>
        </tr>
    <% end %>
  </table>

  <%= render 'dashboard/recent_activity', activities: @recent_activities %>
<% elsif @self_candidate %>
  <p>Welcome, <%= current_user.first_name %>.</p>
  <p>
    Your application is currently
    <strong><%= @self_candidate.candidate_status&.name || @self_candidate.candidate_status&.code || 'in progress' %></strong>.
  </p>
  <p><%= link_to 'View your application', candidate_path(@self_candidate) %></p>
<% else %>
  <p>Welcome, <%= current_user&.first_name %>.</p>
  <p>
    This dashboard is for recruiting staff. If you believe you should have
    access, contact your administrator.
  </p>
<% end %>