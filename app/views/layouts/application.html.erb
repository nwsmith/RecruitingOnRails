<!DOCTYPE html>
<html lang="en" data-theme="<%= cookies[:theme].presence || 'light' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>RecruitingOnRails</title>
  <link rel="icon" type="image/svg+xml" href="<%= asset_path('favicon.svg') %>">
  <%= stylesheet_link_tag "pico.min" %>
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <% if content_for? :for_head %>
      <%= yield :for_head %>
  <% end %>
</head>
<body>
<header class="container">
  <nav>
    <ul>
      <li>
        <%= link_to dashboard_path, class: 'logo-link' do %>
          <%= render 'layouts/logo' %>
          <span class="logo-text">Recruiting<span class="logo-text-accent">onRails</span></span>
        <% end %>
      </li>
    </ul>
    <ul>
      <li><%= link_to "Dashboard", dashboard_path %></li>
      <li><%= link_to "Candidates", candidates_path %></li>
      <li><%= link_to "Reports", reports_index_path %></li>
      <% if current_user %>
        <li><span class="user-chip"><%= current_user.name %></span></li>
      <% end %>
      <li><a href="#" id="theme-toggle" role="button" class="outline secondary" data-theme-toggle>
        <%= cookies[:theme] == "dark" ? "Light mode" : "Dark mode" %>
      </a></li>
    </ul>
  </nav>
</header>

<main class="container">
  <%= yield %>
</main>

<footer class="container">
  <small>RecruitingOnRails &middot; Modernized <%= Date.today.year %></small>
</footer>

</body>
</html>
