<h1>Listing registries</h1>

<table>
  <tr>
    <th>Key</th>
    <th>Value</th>
    <th></th>
    <th></th>
    <th></th>
  </tr>

<% @registries.each do |registry| %>
  <tr>
    <td><%= registry.key %></td>
    <td><%= registry.value %></td>
    <td><%= link_to 'Show', registry %></td>
    <td><%= link_to 'Edit', edit_registry_path(registry) %></td>
    <td><%= button_to 'Destroy', registry, method: :delete, form: { data: { confirm: 'Are you sure?' } } %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New Registry', new_registry_path %>
